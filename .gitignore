.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env.example

# === FIREBASE ===
# Clave privada de la cuenta de servicio (acceso total a tu proyecto)
*-firebase-adminsdk-*.json
firebase-service-account.json
serviceAccountKey.json
firebase-debug.log
firebase-debug.*.log
.firebase/
firestore-debug.log
ui-debug.log

# === LOGS ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === SISTEMA OPERATIVO ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# === IDEs ===
.idea/
.vscode/
.cursor/
*.swp
*.swo
*~

# === TESTING ===
coverage/
.nyc_output/

# === TYPESCRIPT ===
*.tsbuildinfo


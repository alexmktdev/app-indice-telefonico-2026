# ─────────────────────────────────────────────────────────────
# GITIGNORE - Archivos y carpetas que NUNCA deben subir a Git
# ─────────────────────────────────────────────────────────────

# === DEPENDENCIAS ===
node_modules/
.pnp/
.pnp.js

# === NEXT.JS ===
.next/
out/
build/
.vercel/
.turbo/

# === VARIABLES DE ENTORNO (CRÍTICO - NUNCA SUBIR) ===
